# AnythingLLM Environment Configuration
# Copy this file to anythingllm.env and update with your actual values

# LLM Provider (openai, azure, anthropic, etc.)
LLM_PROVIDER='openai'

# Embedding Model Preference
EMBEDDING_MODEL_PREF='text-embedding-ada-002'

# Vector Database (lancedb, pinecone, chroma, etc.)
VECTOR_DB='lancedb'

# Whisper Provider for Speech-to-Text
WHISPER_PROVIDER='local'

# Text-to-Speech Provider
TTS_PROVIDER='native'

# Storage Directory (inside container)
STORAGE_DIR='/app/server/storage'

# Server Port
SERVER_PORT='3001'

# Security Keys - GENERATE YOUR OWN UNIQUE VALUES
# Use: openssl rand -hex 32
SIG_KEY='your-signature-key-here-use-openssl-rand-hex-32'
SIG_SALT='your-signature-salt-here-use-openssl-rand-hex-32'

# HTTPS Configuration
ENABLE_HTTPS='false'
