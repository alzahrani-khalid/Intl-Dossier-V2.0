# AnythingLLM environment template
# Copy to docker/anythingllm.env and fill real values (never commit docker/anythingllm.env)
LLM_PROVIDER='openai'
EMBEDDING_MODEL_PREF='text-embedding-ada-002'
VECTOR_DB='lancedb'
WHISPER_PROVIDER='local'
TTS_PROVIDER='native'
STORAGE_DIR='/app/server/storage'
SERVER_PORT='3001'
SIG_KEY='your_sig_key_here'
SIG_SALT='your_sig_salt_here'
ENABLE_HTTPS='false'
