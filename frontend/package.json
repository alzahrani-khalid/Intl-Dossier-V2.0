{
  "name": "intake-frontend",
  "version": "1.0.0",
  "description": "Frontend for Front Door Intake System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc -p tsconfig.build.json && vite build",
    "build:strict": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "vitest run --config vitest.a11y.config.ts",
    "lint": "eslint src/**/*.{ts,tsx}",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit",
    "add:component": "./scripts/add-component.sh",
    "analyze": "ANALYZE=true vite build",
    "analyze:json": "ANALYZE=true vite build && node -e \"const fs=require('fs');const h=fs.readFileSync('dist/stats.html','utf8');const m=h.match(/window\\.chartData\\s*=\\s*(\\{[\\s\\S]*?\\});/);if(m){const d=JSON.parse(m[1]);fs.writeFileSync('dist/bundle-stats.json',JSON.stringify(d,null,2));}\"",
    "build:ci": "vite build && size-limit",
    "size-limit": "size-limit"
  },
  "size-limit": [
    {
      "name": "Initial JS (entry point)",
      "path": "dist/assets/index-*.js",
      "limit": "200 KB",
      "gzip": true
    },
    {
      "name": "React vendor",
      "path": "dist/assets/react-vendor-*.js",
      "limit": "50 KB",
      "gzip": true
    },
    {
      "name": "TanStack vendor",
      "path": "dist/assets/tanstack-vendor-*.js",
      "limit": "80 KB",
      "gzip": true
    },
    {
      "name": "Total JS",
      "path": "dist/assets/*.js",
      "limit": "800 KB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
