{
  "name": "intake-backend",
  "version": "1.0.0",
  "description": "Backend for Front Door Intake System",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "build:tsc": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest --config ./vitest.config.ts",
    "test:coverage": "vitest --coverage --config ./vitest.config.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "migrate": "supabase migration up",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@mastra/core": "^1.17.0",
    "@sentry/node": "^10.46.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "bullmq": "5.73.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "web-push": "3.6.7",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/json2csv": "^5.0.7",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "exceljs": "^4.4.0",
    "json2csv": "6.0.0-alpha.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
