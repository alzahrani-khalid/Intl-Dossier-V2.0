{
  "name": "intake-backend",
  "version": "1.0.0",
  "description": "Backend for Front Door Intake System",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "build:tsc": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest --config ./vitest.config.ts",
    "test:coverage": "vitest --coverage --config ./vitest.config.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "migrate": "supabase migration up",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@mastra/core": "^0.24.6",
    "@sentry/node": "^9.24.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "openai": "^5.23.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/json2csv": "^5.0.7",
    "@types/node": "^20.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.3",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.24.0",
    "exceljs": "^4.4.0",
    "json2csv": "^6.0.0-alpha.2",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
