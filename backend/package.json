{
  "name": "intake-backend",
  "version": "1.0.0",
  "description": "Backend for Front Door Intake System",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "node build.mjs",
    "build:tsc": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest --config ./vitest.config.ts",
    "test:integration": "vitest --config ./vitest.integration.config.ts --run",
    "test:coverage": "vitest --coverage --config ./vitest.config.ts",
    "lint": "cd .. && eslint -c eslint.config.mjs --max-warnings 0 'backend/src/**/*.ts'",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "type-check:summary": "tsc --noEmit 2>&1 | grep -oE 'TS[0-9]+' | sort | uniq -c | sort -rn || true",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "migrate": "supabase migration up",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@mastra/core": "^1.36.0",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.100.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "5.77.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "9.0.0",
    "openai": "^6.39.0",
    "pdfkit": "^0.18.0",
    "pg": "8.21.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "web-push": "3.6.7",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/json2csv": "^5.0.7",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "8.20.0",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.27.4",
    "exceljs": "^4.4.0",
    "json2csv": "6.0.0-alpha.2",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
