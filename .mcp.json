{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem@latest", "."],
      "env": {}
    },
    "docker": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-docker"],
      "env": {}
    },
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "env": {
        "REGISTRY_URL": "https://www.kibo-ui.com/r/registry.json"
      }
    },
    "anythingllm": {
      "type": "stdio",
      "command": "npx",
      "args": ["anythingllm-mcp-server"],
      "env": {
        "ANYTHINGLLM_API_KEY": "T70PG8S-WRD4EXH-KEVN4ZB-WM1SEG2",
        "ANYTHINGLLM_BASE_URL": "http://localhost:3001/api/v1"
      }
    },
    "heroui-react": {
      "command": "npx",
      "args": ["-y", "@heroui/react-mcp@latest"]
    }
  }
}
