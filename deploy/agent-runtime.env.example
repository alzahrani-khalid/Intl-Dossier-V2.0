# ===========================================
# Agent-Runtime (Mastra + CopilotKit/AG-UI copilot) Environment — Phase 72
# Internal-only service on the intl-dossier Docker network (expose 4100).
# nginx is the only externally-proxied path: /api/copilot/ -> agent-runtime:4100/chat.
#
# These vars are consumed by the agent-runtime service in docker-compose.prod.yml.
# Set the secret-backed ones (ALLOWED_ORIGINS, MASTRA_PG_URL) in deploy/.env on
# the host. The workspace + Dockerfile.prod are built in plan 72-05; this file is
# the env contract those services read.
# ===========================================

# ----- Runtime -----
NODE_ENV=production
PORT=4100

# ----- Supabase (keystone) -----
# The copilot runs every read under the CALLER'S identity: anon key + the user's
# Bearer JWT (delivered via the AG-UI request header). RLS (sensitivity_level <=
# clearance_level) then applies automatically. NEVER set SUPABASE_SERVICE_ROLE_KEY
# here — service-role bypasses RLS and would leak above-clearance content.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ----- CORS (SECRET — never '*') -----
# Comma-separated allow-list of the exact deployed origin(s) the CopilotKit
# provider calls from, e.g. https://intl-dossier.example.com
# WARNING: if this is UNSET the runtime falls back to a deny-all origin list and
# every deployed origin gets ACAO:null (the carried edge-fn lesson). It must be
# set to a real origin, and it must NEVER be the literal '*'.
ALLOWED_ORIGINS=https://your-domain.com

# ----- Model + retrieval backends (internal service names) -----
# vLLM serves Gemma 4 12B over the OpenAI-compatible /v1 (served-model-name
# gemma-4-12b). TEI serves bge-m3 (embeddings) and bge-reranker-v2-m3 (rerank).
VLLM_BASE_URL=http://vllm:8000
TEI_EMBED_URL=http://tei-embed:80
TEI_RERANK_URL=http://tei-rerank:80

# ----- Mastra thread store (@mastra/pg) -----
# @mastra/pg auto-provisions mastra_threads / mastra_messages on the SAME Supabase
# Postgres. Use the direct Postgres connection string (NOT the REST URL):
#   postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
MASTRA_PG_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ----- Observability -----
# Traces export to the internal Phoenix OTLP gRPC receiver (zero external egress).
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317
