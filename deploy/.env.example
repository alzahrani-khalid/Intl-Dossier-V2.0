# ===========================================
# Intl-Dossier Production Environment
# Copy to .env and fill in your values
# ===========================================

# ===========================================
# DOMAIN & URLs
# ===========================================
# Your domain (e.g., intl-dossier.example.com)
DOMAIN=your-domain.com
FRONTEND_URL=https://your-domain.com

# API URL (internal routing uses /api/)
VITE_API_URL=https://your-domain.com/api

# ===========================================
# SUPABASE (from your Supabase dashboard)
# ===========================================
# Project: zkrcjzdemdmwhearthfgg (eu-west-2)
SUPABASE_URL=https://zkrcjzdemdmwhearthfgg.supabase.co
VITE_SUPABASE_URL=https://zkrcjzdemdmwhearthfgg.supabase.co

# Anon/Public key (safe to expose in frontend)
SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key (KEEP SECRET - backend only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# JWT SECRET
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=generate-a-strong-secret-here

# ===========================================
# OPTIONAL: Cloud LLM API KEYS
# ===========================================
# The on-prem copilot stack (vLLM/TEI) needs NO cloud key. These are only for
# any optional cloud-backed path; leave unset for a fully air-gapped deploy.
# Anthropic (if using Claude instead of the on-prem model)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ===========================================
# OPTIONAL: Email (for notifications)
# ===========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# SMTP_FROM=noreply@your-domain.com

# ===========================================
# OPTIONAL: Monitoring
# ===========================================
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=secure-password-here

# ===========================================
# SECURITY NOTES
# ===========================================
# 1. NEVER commit this file to git (it's in .gitignore)
# 2. Use strong, unique passwords
# 3. Rotate keys regularly
# 4. Keep SUPABASE_SERVICE_ROLE_KEY secret

# ===========================================
# REMED-05 OBSERVABILITY (Langfuse + Phoenix) — Phase 68
# Internal Docker network only; zero external egress.
# ===========================================
# Langfuse needs its own Postgres DB (separate from Supabase). Format:
#   postgresql://user:password@host:5432/langfuse
LANGFUSE_DATABASE_URL=postgresql://postgres:password@host:5432/langfuse
# Generate each with: openssl rand -hex 32
LANGFUSE_SECRET=<generate-with-openssl-rand-hex-32>
LANGFUSE_SALT=<generate-with-openssl-rand-hex-32>
# Phoenix OTLP gRPC receiver inside the Docker network (no external host)
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317
