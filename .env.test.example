# Test environment variables
# Copy this file to .env.test and fill in actual values.
# WARNING: Never commit .env.test — it contains real credentials and the
# Supabase service-role key. Only .env.test.example is tracked in git.

# Supabase connection (used by test helpers and E2E cleanup)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key — required by tests/e2e/support/helpers/supabase-admin.ts
# to clean up E2E-created rows. NEVER ship this to client bundles.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL for Playwright runs. Defaults to http://localhost:5173 locally.
E2E_BASE_URL=http://localhost:5173

# Legacy single-user credentials (kept for backwards compatibility with
# existing integration tests). Prefer the role-scoped pairs below for E2E.
TEST_USER_EMAIL=your-test-email@example.com
TEST_USER_PASSWORD=your-test-password

# Role-scoped E2E credentials — consumed by tests/e2e/support/auth.setup.ts
# to produce storageState JSON per role. These accounts must exist in the
# Supabase project pointed to by SUPABASE_URL (seeded by Phase 17).
E2E_ADMIN_EMAIL=e2e-admin@example.com
E2E_ADMIN_PASSWORD=change-me
E2E_ANALYST_EMAIL=e2e-analyst@example.com
E2E_ANALYST_PASSWORD=change-me
E2E_INTAKE_EMAIL=e2e-intake@example.com
E2E_INTAKE_PASSWORD=change-me

# Phase 52 fixture engagement — used by the Kanban visual / dnd / keyboard / a11y specs
# (tasks-tab-*.spec.ts and engagement-kanban-dialog-*.spec.ts). Must point to a staging
# engagement whose assignments distribution matches the D-16 composition contract:
# todo:2, in_progress:2, review:1, done:2, cancelled:1 (8 rows total).
# Specs fall back to the canonical UUID 00000000-0000-0052-0000-000000000001 when unset.
# See .planning/phases/52-heroui-v3-kanban-migration/52-FIXTURE.md for the seed contract.
PHASE_52_FIXTURE_ENGAGEMENT_ID=00000000-0000-0052-0000-000000000001
