# ===========================================
# agent-runtime — on-prem copilot runtime (Phase 72)
# Mastra + self-hosted CopilotKit/AG-UI on :4100
# ===========================================

# --- Server ---
# Port the Mastra/AG-UI SSE server binds to (backend=4000, anythingllm=3001,
# langfuse=3000, phoenix=6006/4317). NEVER 5000 (macOS AirPlay).
PORT=4100
NODE_ENV=development

# --- CORS (keystone, MEMORY edge-fn lesson) ---
# CSV of allowed origins. NEVER '*'. Unset => ACAO:null on deployed origins.
# e.g. https://app.example.com,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# --- Model endpoint (D-02, OpenAI-compatible; vLLM in prod / Ollama in dev) ---
# Set VLLM_BASE_URL in prod (the runtime defaults the copilot provider to vllm).
# In local dev, set OLLAMA_BASE_URL instead and the runtime falls back to ollama.
VLLM_BASE_URL=
VLLM_MODEL=gemma-4-12b
# Local dev fallback:
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:30b
# On-prem server ignores this; required non-empty by the AI-SDK. NOT a cloud key.
VLLM_API_KEY=on-prem-no-key

# --- Retrieval backends (TEI) ---
# Consumed by the hybrid-RAG tool + the re-embed job. In compose these resolve by
# service name on the intl-dossier network. Defaults match docker-compose.prod.yml.
TEI_EMBED_URL=http://tei-embed:80
TEI_RERANK_URL=http://tei-rerank:80
# pnpm-dev (non-docker) variant: point at the host-published CPU TEI containers you
# run standalone for `pnpm --filter agent-runtime dev` (see deploy/MAC-LOCAL.md).
# TEI_EMBED_URL=http://127.0.0.1:8081
# TEI_RERANK_URL=http://127.0.0.1:8082

# --- Supabase (anon key ONLY — the caller JWT enforces RLS; NO service-role) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Persistent threads (@mastra/pg PostgresStore, D-08) ---
# Postgres connection string for mastra_threads/mastra_messages (owner-only RLS).
MASTRA_PG_URL=

# --- Observability (zero external egress) ---
# OTLP gRPC endpoint for the self-hosted Phoenix collector.
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317

# --- Air-gap note ---
# This is the SELF-HOSTED CopilotKit runtime: it requires NO Copilot Cloud key
# (no COPILOT_CLOUD_PUBLIC_API_KEY). Air-gap was proven in the 72-01 spike (GATE 3).
