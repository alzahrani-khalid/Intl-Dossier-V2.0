# Mirror the workspace-root .npmrc so the STANDALONE image install resolves the same
# transitive/peer deps that dev does. @copilotkit/runtime's barrel statically imports
# ALL of its service adapters (openai/anthropic/google/groq/langchain/bedrock/unify),
# so their peer SDKs must be installed AND hoisted to the top-level node_modules —
# pnpm's default isolated linker leaves a peer unresolvable for the package importing
# it (the `Cannot find package 'openai'` crash). shamefully-hoist flattens them so
# node's resolver finds them at runtime; auto-install-peers pulls the declared peers.
shamefully-hoist=true
auto-install-peers=true
