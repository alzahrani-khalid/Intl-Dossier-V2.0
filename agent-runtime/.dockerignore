# Docker build-context excludes. Without `node_modules` here, the host's macOS-arm64
# node_modules is copied by `COPY . .` and clobbers the clean in-image Linux install,
# breaking the standalone build. `spike/` is the throwaway standalone package (kept
# OUT of the workspace) and is not part of the runtime image.
node_modules
dist
spike
.env
.env.*
.git
.gitignore
.turbo
coverage
*.log
.DS_Store
Dockerfile*
.dockerignore
