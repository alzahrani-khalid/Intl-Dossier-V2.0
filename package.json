{
  "name": "intl-dossierv2.0",
  "version": "1.0.0",
  "description": "GASTAT International Dossier Management System",
  "private": true,
  "packageManager": "pnpm@10.29.1+sha512.48dae233635a645768a3028d19545cacc1688639eeb1f3734e42d6d6b971afbf22aa1ac9af52a173d9c3a20c15857cfa400f19994d79a2f626fcc73fccda9bbc",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run type-check",
    "prepare": "husky",
    "db:setup": "pnpm run db:migrate && pnpm run db:seed",
    "db:migrate": "cd backend && pnpm run migrate",
    "db:rollback": "cd backend && pnpm run migrate:down",
    "db:seed": "cd backend && pnpm run seed",
    "db:reset": "pnpm run db:rollback && pnpm run db:migrate && pnpm run db:seed",
    "countries:populate": "pnpm exec tsx scripts/populate-countries.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "monitor": "docker-compose up -d prometheus grafana",
    "clean": "turbo run clean && rm -rf node_modules */node_modules",
    "fresh": "pnpm run clean && pnpm install && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alzahrani-khalid/Intl-Dossier-V2.0.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/alzahrani-khalid/Intl-Dossier-V2.0/issues"
  },
  "homepage": "https://github.com/alzahrani-khalid/Intl-Dossier-V2.0#readme",
  "lint-staged": {
    "frontend/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "backend/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.17",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "axe-playwright": "^2.2.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.1",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "shadcn": "^3.4.0",
    "turbo": "^2.6.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@upstash/redis": "^1.35.5",
    "react": "^19.2.4"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.34.5"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "tailwindcss": "4",
        "dotenv": "17",
        "openai": "5",
        "@babel/core": "7",
        "ai": ">=4"
      },
      "ignoreMissing": [
        "@babel/preset-es2015"
      ]
    }
  }
}
